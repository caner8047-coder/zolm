{
  "manifest_version": 3,
  "name": "ZOLM Trendyol Booster Companion",
  "version": "1.1.0",
  "description": "Trendyol fırsat ve toplu karar kuyruğunu, medya merkezini ve Seller Panel kârlılığını ZOLM'a taşır.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "activeTab", "tabs", "scripting", "alarms"],
  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*",
    "http://localhost:*/*",
    "https://localhost:*/*",
    "http://127.0.0.1:*/*",
    "https://127.0.0.1:*/*",
    "https://m.zolm.com.tr/*",
    "https://www.trendyol.com/*",
    "https://*.trendyol.com/*",
    "https://*.dsmcdn.com/*",
    "https://partner.trendyol.com/*",
    "https://ty.gl/*",
    "https://www.google.com/*",
    "https://google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.trendyol.com/*", "https://*.trendyol.com/*"],
      "exclude_matches": ["https://partner.trendyol.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://partner.trendyol.com/*"],
      "js": ["profit-calculator.js", "seller-panel.js", "campaign-panel.js", "orders-panel.js", "seller-profit-overlay.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost/*",
        "https://localhost/*",
        "http://127.0.0.1/*",
        "https://127.0.0.1/*",
        "http://localhost:*/*",
        "https://localhost:*/*",
        "http://127.0.0.1:*/*",
        "https://127.0.0.1:*/*",
        "https://m.zolm.com.tr/*"
      ],
      "js": ["zolm-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "ZOLM Booster",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
